pkgname=libssc
pkgver=0.2.2
pkgrel=1
pkgdesc="Library to expose Qualcomm Sensor Core sensors"
arch=('x86_64' 'aarch64')
url="https://codeberg.org/DylanVanAssche/libssc"
license=('GPL3')
depends=('protobuf-c' 'glib2' 'libgudev' 'libqmi' 'qrtr' 'systemd' 'python')
makedepends=('meson' 'gcc' 'python')
source=("https://codeberg.org/DylanVanAssche/libssc/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname"
  meson setup build --prefix=/usr
  ninja -C build
}

package() {
  cd "$pkgname"
  DESTDIR="$pkgdir" ninja -C build install
}
