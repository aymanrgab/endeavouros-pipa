pkgname=pipa-sensors
pkgver=1.2
pkgrel=1
pkgdesc="Sensors configs for the Xiaomi Pad 6"
arch=('any')
license=('MIT')
depends=('xiaomi-pipa-firmware' 'iio-sensor-proxy-pipa' 'hexagonrpc')
source=('81-libssc-xiaomi-pipa.rules' 'hexagonrpcd-sdsp.conf')
sha256sums=('SKIP' 'SKIP')

package() {
  install -Dm644 81-libssc-xiaomi-pipa.rules "$pkgdir/usr/lib/udev/rules.d/81-libssc-xiaomi-pipa.rules"
  install -Dm644 hexagonrpcd-sdsp.conf "$pkgdir/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf"
}
