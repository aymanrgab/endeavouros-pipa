pkgname=bootmac
pkgver=0.6.0
pkgrel=1
pkgdesc="Configures the MAC addresses of WLAN and Bluetooth interfaces at boot"
arch=('any')
url="https://gitlab.postmarketos.org/postmarketOS/bootmac"
license=('GPL3')
depends=('bluez-utils' 'systemd')
source=("https://gitlab.postmarketos.org/postmarketOS/bootmac/-/archive/v${pkgver}/bootmac-v${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "$pkgname-v$pkgver"
  install -Dm755 bootmac "$pkgdir/usr/bin/bootmac"
  install -Dm644 bootmac-bluetooth.service "$pkgdir/usr/lib/systemd/system/bootmac-bluetooth.service"
  install -Dm644 bootmac-wifi.rules "$pkgdir/usr/lib/udev/rules.d/70-bootmac-wifi.rules"
}
