pkgname=iio-sensor-proxy-pipa
pkgver=3.7
pkgrel=2
pkgdesc="IIO accelerometer sensor to input device proxy (with libssc support)"
arch=('x86_64' 'aarch64')
url="https://gitlab.freedesktop.org/hadess/iio-sensor-proxy"
license=('GPL3')
depends=('dbus' 'glib2' 'hexagonrpc' 'libgudev' 'libssc' 'polkit' 'systemd')
makedepends=('meson' 'gcc' 'gtk-doc' 'umockdev')
provides=('iio-sensor-proxy')
conflicts=('iio-sensor-proxy')
source=("https://gitlab.freedesktop.org/hadess/iio-sensor-proxy/-/archive/${pkgver}/iio-sensor-proxy-${pkgver}.tar.gz"
        "0001-iio-sensor-proxy-depend-on-libssc.patch"
        "0002-proximity-support-SSC-proximity-sensor.patch"
        "0003-light-support-SSC-light-sensor.patch"
        "0004-accelerometer-support-SSC-accelerometer-sensor.patch"
        "0005-compass-support-SSC-compass-sensor.patch"
        "0006-data-add-libssc-udev-rules.patch"
        "0007-data-iio-sensor-proxy.service.in-add-AF_QIPCRTR.patch"
        "0008-drv-ssc-implement-set_polling.patch"
        "0009-tests-integration-test-add-SSC-sensors.patch")
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

prepare() {
  cd "iio-sensor-proxy-$pkgver"
  patch -p1 < ../0001-iio-sensor-proxy-depend-on-libssc.patch
  patch -p1 < ../0002-proximity-support-SSC-proximity-sensor.patch
  patch -p1 < ../0003-light-support-SSC-light-sensor.patch
  patch -p1 < ../0004-accelerometer-support-SSC-accelerometer-sensor.patch
  patch -p1 < ../0005-compass-support-SSC-compass-sensor.patch
  patch -p1 < ../0006-data-add-libssc-udev-rules.patch
  patch -p1 < ../0007-data-iio-sensor-proxy.service.in-add-AF_QIPCRTR.patch
  patch -p1 < ../0008-drv-ssc-implement-set_polling.patch
  patch -p1 < ../0009-tests-integration-test-add-SSC-sensors.patch
}

build() {
  cd "iio-sensor-proxy-$pkgver"
  meson setup build --prefix=/usr -Dgtk-tests=false -Dssc-support=true
  ninja -C build
}

package() {
  cd "iio-sensor-proxy-$pkgver"
  DESTDIR="$pkgdir" ninja -C build install

  install -d "$pkgdir/usr/lib/systemd/system/iio-sensor-proxy.service.d"
  cat > "$pkgdir/usr/lib/systemd/system/iio-sensor-proxy.service.d/hexagonrpcd.conf" <<'EOF'
[Unit]
Wants=hexagonrpcd-adsp-rootpd.service
Wants=hexagonrpcd-sdsp.service
After=hexagonrpcd-adsp-rootpd.service
After=hexagonrpcd-sdsp.service
EOF

  install -d "$pkgdir/etc/systemd/system/iio-sensor-proxy.service.d"
  cat > "$pkgdir/etc/systemd/system/iio-sensor-proxy.service.d/override.conf" <<'EOF'
[Service]
Restart=always
RestartSec=5
EOF
}
