pkgname=hexagonrpc
pkgver=0.3.2
pkgrel=1
pkgdesc="FastRPC ioctl wrapper and a reverse tunnel"
arch=('x86_64' 'aarch64')
url="https://github.com/linux-msm/hexagonrpc"
license=('GPL3')
depends=('systemd')
makedepends=('meson' 'gcc')
source=("https://github.com/linux-msm/hexagonrpc/archive/refs/tags/v${pkgver}.tar.gz"
        "hexagonrpcd-adsp-rootpd.service"
        "hexagonrpcd-adsp-sensorspd.service"
        "hexagonrpcd-sdsp.service"
        "sysusers.conf"
        "10-fastrpc.rules")
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

build() {
  cd "$pkgname-$pkgver"
  meson setup build --prefix=/usr --libexecdir=lib
  ninja -C build
}

package() {
  cd "$pkgname-$pkgver"
  DESTDIR="$pkgdir" ninja -C build install
  
  install -d "$pkgdir/usr/include"
  cp -a include/libhexagonrpc "$pkgdir/usr/include/"
  
  install -Dm644 ../hexagonrpcd-adsp-rootpd.service "$pkgdir/usr/lib/systemd/system/hexagonrpcd-adsp-rootpd.service"
  install -Dm644 ../hexagonrpcd-adsp-sensorspd.service "$pkgdir/usr/lib/systemd/system/hexagonrpcd-adsp-sensorspd.service"
  install -Dm644 ../hexagonrpcd-sdsp.service "$pkgdir/usr/lib/systemd/system/hexagonrpcd-sdsp.service"
  
  install -Dm644 ../sysusers.conf "$pkgdir/usr/lib/sysusers.d/fastrpc.conf"
  install -Dm644 ../10-fastrpc.rules "$pkgdir/usr/lib/udev/rules.d/10-fastrpc.rules"
}
