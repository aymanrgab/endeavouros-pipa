pkgname=tqftpserv
pkgver=1.0
pkgrel=1
pkgdesc="Qualcomm Trivial File Transfer Protocol Server"
arch=('aarch64')
url="https://github.com/linux-msm/tqftpserv"
license=('BSD')
depends=('qrtr')
makedepends=('git' 'meson' 'ninja')
source=("git+https://github.com/linux-msm/tqftpserv.git")
md5sums=('SKIP')

build() {
  cd "$srcdir/$pkgname"
  meson setup build --prefix=/usr --sysconfdir=/etc
  meson compile -C build
}

package() {
  cd "$srcdir/$pkgname"
  meson install -C build --destdir="$pkgdir"
}
