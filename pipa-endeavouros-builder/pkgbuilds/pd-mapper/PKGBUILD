pkgname=pd-mapper
pkgver=1.0
pkgrel=1
pkgdesc="Qualcomm Protection Domain Mapper"
arch=('aarch64')
url="https://github.com/linux-msm/pd-mapper"
license=('BSD')
depends=('qrtr')
makedepends=('git' 'meson' 'ninja')
provides=('pd-mapper-git')
conflicts=('pd-mapper-git')
source=("git+https://github.com/linux-msm/pd-mapper.git")
md5sums=('SKIP')

build() {
  cd "$srcdir/$pkgname"
  meson setup build --prefix=/usr --sysconfdir=/etc
  meson compile -C build
}

package() {
  cd "$srcdir/$pkgname"
  meson install -C build --destdir="$pkgdir"
}
