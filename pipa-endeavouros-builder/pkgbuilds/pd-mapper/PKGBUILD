pkgname=pd-mapper
pkgver=1.0
pkgrel=1
pkgdesc="Qualcomm Protection Domain Mapper"
arch=('aarch64')
url="https://github.com/linux-msm/pd-mapper"
license=('BSD')
depends=('qrtr' 'xz')
makedepends=('git' 'make')
provides=('pd-mapper-git')
conflicts=('pd-mapper-git')
source=("git+https://github.com/linux-msm/pd-mapper.git")
md5sums=('SKIP')

build() {
  cd "$srcdir/$pkgname"
  make prefix=/usr
}

package() {
  cd "$srcdir/$pkgname"
  make DESTDIR="$pkgdir" prefix=/usr install
}
