pkgname=xiaomi-pipa-firmware
pkgver=1.1
pkgrel=2
_commit=842d35beffeda8c6d1b0e611b335543bf0e6b41e
pkgdesc="Firmware package for Xiaomi Pad 6 (pipa)"
arch=('any')
url="https://github.com/pipa-mainline/xiaomi-pipa-firmware"
license=('custom')
depends=('linux-firmware-qcom')
source=("${pkgname}-${_commit}.tar.gz::https://github.com/pipa-mainline/xiaomi-pipa-firmware/archive/${_commit}.tar.gz"
        'awinic_firmware.files'
        'dsp_firmware.files'
        'qcom_firmware.files'
        'novatek_firmware.files')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
  cd "$pkgname-$_commit"
  
  for firmware in $(cat ../awinic_firmware.files); do
    install -Dm644 "$firmware" "$pkgdir/usr/lib/firmware/awinic/$(basename "$firmware")"
  done
  
  for firmware in $(cat ../dsp_firmware.files); do
    install -Dm644 "$firmware" "$pkgdir/$firmware"
  done
  
  for firmware in $(cat ../qcom_firmware.files); do
    install -Dm644 "$firmware" "$pkgdir/usr/lib/firmware/qcom/sm8250/xiaomi/pipa/$(basename "$firmware")"
  done
  
  for firmware in $(cat ../novatek_firmware.files); do
    install -Dm644 "$firmware" "$pkgdir/usr/lib/firmware/novatek/$(basename "$firmware")"
  done
}
